# URL бэкенда Consilium API (попадает в сборку Flutter web)
API_BASE_URL=http://5.42.113.18:8001

# Порт, на котором сайт будет доступен на сервере
WEB_PORT=8083

# O4 — release (по умолчанию), O1 — быстрее собирается на слабом VPS
# DART2JS_OPTIMIZATION=O1

# --- Docker ---
# cp .env.example .env
#
# Пересборка и запуск (после изменений в коде):
#   docker compose up -d --build --force-recreate
#
# Автопересборка при изменении lib/ (в отдельном терминале):
#   docker compose watch
#
# Проверить версию сборки в контейнере:
#   curl http://localhost:8083/build-id.txt
#
# Проверить, что нет старого secure storage (generateKey):
#   docker compose exec consul-web grep -c generateKey /usr/share/nginx/html/main.dart.js
#   (должно быть 0)
